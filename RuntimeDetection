import psutil
import time
import ctypes
import datetime

GAME_PROCESS_NAME = "YourGame.exe"  # Replace with your game's process name
TIME_LIMIT_SECONDS = 120  # 120 minutes

session_started = None
time_limit_reached = False

def is_game_running():
    for proc in psutil.process_iter(['name']):
        try:
            if proc.info['name'] and proc.info['name'].lower() == GAME_PROCESS_NAME.lower():
                return True
        except (psutil.NoSuchProcess, psutil.AccessDenied):
            continue
    return False

def show_notification(title, message):
    ctypes.windll.user32.MessageBoxW(0, message, title, 0x40 | 0x1)

print("Monitoring for game process...")

def close_game():
    pass

while True:
    if is_game_running():
        if session_started is None:
            session_started = datetime.datetime.now()
            print(f"Game started at {session_started}")
       
        elapsed_time = (datetime.datetime.now() - session_started).total_seconds()
       
        if elapsed_time >= TIME_LIMIT_SECONDS and not time_limit_reached:
            show_notification("Time Limit Reached", "You have reached your gaming time limit!")
            time_limit_reached = True
    else:
        if session_started is not None:
            print("Game closed. Resetting timer.")
        session_started = None
        time_limit_reached = False
   
    time.sleep(5)  # Check every 5 seconds

